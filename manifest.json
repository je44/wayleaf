{
  "manifest_version": 3,
  "name": "tab-tab",
  "description": "tab-tab 用门户快捷入口、书签文件夹和最近历史记录替代 Chrome 新标签页。",
  "version": "1.0.0",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "bookmarks",
    "favicon",
    "history",
    "storage"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
