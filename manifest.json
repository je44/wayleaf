{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "version": "1.6.0",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "alarms",
    "bookmarks",
    "favicon",
    "history",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*",
        "https://chat.deepseek.com/*",
        "https://www.doubao.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://chatglm.cn/*",
        "https://z.ai/*",
        "https://jimeng.jianying.com/*"
      ],
      "js": [
        "ai-submit.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://youtube.com/*",
        "*://*.youtube.com/*",
        "*://bilibili.com/*",
        "*://*.bilibili.com/*"
      ],
      "js": [
        "video-pip.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Wayleaf",
    "default_icon": {
      "16": "icons/wayleaf-flat-16.png",
      "32": "icons/wayleaf-flat-32.png",
      "48": "icons/wayleaf-flat-48.png",
      "128": "icons/wayleaf-flat-128.png"
    }
  },
  "icons": {
    "16": "icons/wayleaf-flat-16.png",
    "32": "icons/wayleaf-flat-32.png",
    "48": "icons/wayleaf-flat-48.png",
    "128": "icons/wayleaf-flat-128.png"
  }
}
