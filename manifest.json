{
  "manifest_version": 3,
  "name": "Wayleaf",
  "description": "Wayleaf 用门户快捷入口、书签文件夹和最近历史记录替代 Chrome 新标签页。",
  "version": "1.4.0",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "bookmarks",
    "favicon",
    "history",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://grok.com/*"
      ],
      "js": [
        "ai-submit.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Wayleaf",
    "default_icon": {
      "16": "icons/wayleaf-flat-16.png",
      "32": "icons/wayleaf-flat-32.png",
      "48": "icons/wayleaf-flat-48.png",
      "128": "icons/wayleaf-flat-128.png"
    }
  },
  "icons": {
    "16": "icons/wayleaf-flat-16.png",
    "32": "icons/wayleaf-flat-32.png",
    "48": "icons/wayleaf-flat-48.png",
    "128": "icons/wayleaf-flat-128.png"
  }
}
